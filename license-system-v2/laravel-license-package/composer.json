{
    "name": "nirbhay-bs/laravel-license",
    "description": "Offline Ed25519 license verification package for Laravel 11",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "ext-sodium": "*",
        "ext-openssl": "*",
        "illuminate/support": "^11.0",
        "illuminate/console": "^11.0",
        "illuminate/http": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "YourVendor\\LaravelLicense\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "YourVendor\\LaravelLicense\\LicenseServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
